generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  role          String
  passwordHash  String?
  accountStatus String       @default("invited")
  invitedAt     DateTime?
  verifiedAt    DateTime?
  suspendedAt   DateTime?
  lastLoginAt   DateTime?
  parent        Parent?
  staff         Staff?
  invitations   Invitation[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Parent {
  id        String    @id @default(cuid())
  userId    String    @unique
  phone     String
  user      User      @relation(fields: [userId], references: [id])
  children  Child[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Staff {
  id          String        @id @default(cuid())
  userId      String        @unique
  roleTitle   String
  user        User          @relation(fields: [userId], references: [id])
  classrooms  Classroom[]
  reports     DailyReport[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Classroom {
  id          String   @id @default(cuid())
  name        String
  ageGroup    String
  leadStaffId String?
  leadStaff   Staff?   @relation(fields: [leadStaffId], references: [id])
  children    Child[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadStaffId])
}

model Child {
  id                String             @id @default(cuid())
  name              String
  dateOfBirth       DateTime?
  classroomId       String?
  parentId          String?
  classroom         Classroom?         @relation(fields: [classroomId], references: [id])
  parent            Parent?            @relation(fields: [parentId], references: [id])
  attendanceRecords Attendance[]
  dailyReports      DailyReport[]
  authorizedPickups AuthorizedPickup[]
  healthRecords     HealthRecord[]
  allergies         Allergy[]
  incidents         Incident[]
  mediaFiles        MediaFile[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([classroomId])
  @@index([parentId])
}

model Attendance {
  id           String    @id @default(cuid())
  childId      String
  date         DateTime
  status       String
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  child        Child     @relation(fields: [childId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([childId])
}

model DailyReport {
  id           String   @id @default(cuid())
  childId      String
  staffId      String?
  date         DateTime
  meals        String
  nap          String
  learningNote String
  status       String
  child        Child    @relation(fields: [childId], references: [id])
  staff        Staff?   @relation(fields: [staffId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([childId])
  @@index([staffId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([threadId])
}

model Invoice {
  id        String    @id @default(cuid())
  parentId  String
  amount    Decimal
  dueDate   DateTime
  status    String
  parent    Parent    @relation(fields: [parentId], references: [id])
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([parentId])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Decimal
  paidAt    DateTime
  method    String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model AuthorizedPickup {
  id           String   @id @default(cuid())
  childId      String
  name         String
  relationship String
  phone        String
  child        Child    @relation(fields: [childId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([childId])
}

model HealthRecord {
  id        String   @id @default(cuid())
  childId   String
  notes     String
  child     Child    @relation(fields: [childId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

model Allergy {
  id        String   @id @default(cuid())
  childId   String
  allergen  String
  severity  String
  notes     String?
  child     Child    @relation(fields: [childId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

model Incident {
  id        String   @id @default(cuid())
  childId   String
  date      DateTime
  summary   String
  severity  String
  child     Child    @relation(fields: [childId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  audience  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([audience])
}

model MediaFile {
  id        String   @id @default(cuid())
  childId   String?
  fileName  String
  mimeType  String
  url       String
  child     Child?   @relation(fields: [childId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

model Invitation {
  id        String    @id @default(cuid())
  userId    String?
  email     String
  role      String
  status    String    @default("draft")
  token     String    @unique
  sentAt    DateTime?
  acceptedAt DateTime?
  expiresAt DateTime
  user      User?     @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  event     String
  target    String
  detail    String
  createdAt DateTime @default(now())

  @@index([target])
}

model AdmissionApplication {
  id               String    @id @default(cuid())
  parentName       String
  parentEmail      String
  parentPhone      String
  childName        String
  childDateOfBirth DateTime?
  programme        String
  preferredStart   DateTime?
  notes            String?
  status           String    @default("new")
  adminNote        String?
  convertedChildId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
}
