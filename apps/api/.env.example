PORT=4000
WEB_ORIGIN="http://localhost:3000"

# Supabase Postgres connection string.
# In Supabase: Project Settings -> Database -> Connection string.
# Use the URI format and replace [YOUR-PASSWORD] with the database password.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?schema=public&sslmode=require&pgbouncer=true&connection_limit=10"

# Invitation email delivery. Required for admin-created account invitations.
EMAIL_PROVIDER="resend"
EMAIL_FROM="Babies & Todd's Academy <noreply@yourdomain.com>"
RESEND_API_KEY="your-resend-api-key"
