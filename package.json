{
  "name": "babies-tods-academy",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @babies-tods/shared && npm run prisma:generate -w @babies-tods/api",
    "dev": "concurrently \"npm run dev -w @babies-tods/web\" \"npm run dev -w @babies-tods/api\" \"npm run dev:browser\"",
    "edv": "npm run dev",
    "dev:browser": "node scripts/open-dev-browser.js",
    "dev:web": "npm run dev -w @babies-tods/web",
    "dev:api": "npm run dev -w @babies-tods/api",
    "build": "npm run build -w @babies-tods/shared && npm run build -w @babies-tods/api && npm run build -w @babies-tods/web",
    "build:web": "npm run build -w @babies-tods/web",
    "build:api": "npm run build -w @babies-tods/api",
    "lint": "npm run lint -w @babies-tods/web",
    "prisma:generate": "npm run prisma:generate -w @babies-tods/api",
    "db:generate": "npm run prisma:generate -w @babies-tods/api",
    "db:migrate": "npm run prisma:migrate -w @babies-tods/api --",
    "db:seed": "npm run prisma:seed -w @babies-tods/api",
    "db:studio": "npm run prisma:studio -w @babies-tods/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "multer": "^2.2.0",
    "postcss": "^8.5.15"
  }
}
